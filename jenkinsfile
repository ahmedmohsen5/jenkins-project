pipeline {
    agent {
        label 'agent1'
    }
    environment {
        DOCKER_HOST = 'tcp://jenkins-docker:2375'
    }

    stages {
        stage('Build') {
            steps {
                echo 'Building...'
                sh 'docker build -t my-app:latest devops-helper'
            }
        }
        stage('push') {
            steps {
                echo 'Pushing...'
                sh 'docker tag my-app:latest docker-repository:8000/my-app:latest'
                sh 'docker push docker-repository:8000/my-app:latest'
            }
        }
    }
}

